#!/usr/bin/env fish

# mc-tui - Interactive TUI for the Craft Ops Minecraft command cheatsheet
#          (sibling of pkg-tui in the dotfiles): browse the same commands
#          as the docs site, fill in the blanks, then copy them to the
#          clipboard or run them over RCON with mcrcon.
#
# Category view:  every command category, plus [console] (interactive
#                 session — nmcrcon if installed, else mcrcon -t),
#                 [players] (saved player names) and
#                 [settings] (RCON host / port / password).
# Command view:   live preview, placeholders like <player> <item> <x>
#                 are filled via pickers (players, items, enchantments,
#                 effects, entities, ...) or a quick prompt.
#
# Command view keys:
#   enter   fill placeholders, then action menu (copy / run / edit)
#   ctrl-y  fill + copy to clipboard      ctrl-r  fill + run over RCON
#   esc     back / quit
#
# Subcommands:
#   mc-tui console        interactive RCON session with the saved settings
#   mc-tui run <cmd...>   one-shot command (scripts, backups)
#   mc-tui session [tmux|zellij]   TUI + console side by side (default: tmux)
#   mc-tui map [player]   open the world on chunkbase (centered on a player)
#   mc-tui follow [player] [secs]   live map: chromium tab re-centered on a player
#
# Config:  ~/.config/mc-tui/rcon.conf    (chmod 600 — RCON is plaintext!)
# Players: ~/.config/mc-tui/players      (one name per line)

set -g SELF (path resolve (status filename))
set -g CFGDIR $HOME/.config/mc-tui
set -g CONF $CFGDIR/rcon.conf
set -g PLAYERS $CFGDIR/players

function _die
    echo "mc-tui: $argv" >&2
    exit 1
end

# --- modules ---------------------------------------------------------------
# Function definitions live in lib/*.fish, sourced relative to this entry so
# symlinks resolve (SELF is the resolved path). Globals above are set first;
# the libraries only define functions (and STATUS_CACHE, which needs CFGDIR).
# Dispatch runs at the end, by which point every function is defined.
set -l libdir (path dirname -- $SELF)/lib
for _m in data config rcon status world players pickers views railroad session
    source $libdir/$_m.fish
end

# --- entrypoint ------------------------------------------------------------------
# mc-tui              the TUI
# mc-tui console      interactive RCON session (nmcrcon/mcrcon) with saved settings
# mc-tui run <cmd...> one-shot command with saved settings (for scripts/backups)
# mc-tui session [tmux|zellij]   TUI + console side by side (default: tmux)
# mc-tui map [player]            open the world on chunkbase (centered on player)
# mc-tui follow [player] [secs]  live map: chromium tab re-centered every N s
#                                (no player: pick from who's online, ask interval)
# mc-tui rail <compile|run|validate> <file.yml> [player]
#                                railroad: compile a YAML line to commands, run it
#                                over RCON, or validate it; [player] resolves
#                                from:player / dir:auto from their live pose
# mc-tui status [--raw]          server reachability (cached); --raw: just up/down/...

switch "$argv[1]"
    case status # cached reachability — `--raw` for scripts, else a friendly line
        if test "$argv[2]" = --raw
            server_status
        else
            status_line
        end
    case __status # always-fresh machine-readable state (for scripts/healthchecks)
        status_refresh
    case console
        rcon_term; or pause
    case run
        test (count $argv) -ge 2; or _die 'usage: mc-tui run <command...>'
        rcon_exec (string join ' ' -- $argv[2..])
    case rail # railroad builder: compile|run|validate a YAML line definition
        load_conf
        rail_cli $argv[2..]
    case session
        term_session $argv[2]
    case map
        load_conf
        set seed (world_seed); or _die 'could not read the world seed over RCON'
        if test -n "$argv[2]"
            set loc (player_loc $argv[2])
            test (count $loc) -ge 3; or _die "could not read $argv[2]'s position (online?)"
            open_url (chunkbase_url $seed $loc[1] $loc[2] $loc[3])
        else
            open_url (chunkbase_url $seed overworld 0 0)
        end
    case follow
        load_conf
        if test -n "$argv[2]"
            follow_player $argv[2] $argv[3]
        else
            follow_interactive
        end
    case __loc # machine-readable "dim x z" for a player (for follow-map.py)
        load_conf
        player_loc $argv[2]
    case __pose # machine-readable "dim x y z dir" for a player (railroad builder)
        load_conf
        player_pose $argv[2]
    case __seed # machine-readable seed (for follow-map.py)
        load_conf
        world_seed
    case __dump # mc-tui __dump catalog|items|enchantments|... (for scripting)
        if functions -q data_$argv[2]
            data_$argv[2]
        else if contains -- "$argv[2]" catalog items
            $argv[2]
        else
            _die "no such table: $argv[2]"
        end
    case __preview
        preview_cmd $argv[2]
    case __catpreview
        preview_cat (string replace -r '  +.*$' '' -- $argv[2] | string trim)
    case ''
        main
    case '*'
        _die "unknown argument: $argv[1]"
end
